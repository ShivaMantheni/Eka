# ============================================================
# Eka Automation — Environment Configuration
# Copy this file to .env and fill in real values
# NEVER commit .env to version control
# ============================================================

# ── PostgreSQL Database ────────────────────────────────────
POSTGRES_DB=eka_automation
POSTGRES_USER=eka_user
POSTGRES_PASSWORD=eka_secret_change_me

# ── Application Security ───────────────────────────────────
SECRET_KEY=eka-super-secret-key-change-in-production-32chars

# ── SpyTest Remote Paths ───────────────────────────────────
SPYTEST_BASE=/home/hp_test/Eka/sonic-mgmt/spytest

# ── VS Manager Defaults ────────────────────────────────────
VS_SOURCE_IMAGE=/home/hp/anuradha_build_imgs/target/sonic-vs.img
